# ─── Database (SQL Server) ──────────────────────────────────────────────────
# DB_HOST: IP hoặc hostname của SQL Server (không phải localhost nếu chạy ngoài Docker)
DB_HOST=192.168.1.100
DB_PORT=1433
DB_NAME=ocr_db
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!

# ─── Keycloak ───────────────────────────────────────────────────────────────
# KEYCLOAK_URL: URL public của Keycloak (phải truy cập được từ container backend)
KEYCLOAK_URL=https://keycloak.yourdomain.com
KEYCLOAK_REALM=OCR
KEYCLOAK_CLIENT_ID=ocr
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
# Lưu ý: KEYCLOAK_ADMIN_USERNAME/PASSWORD đã bỏ.
# Thay bằng service account – xem app/services/keycloak_service.py

# ─── Google Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── File Storage ──────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ─── Application ───────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-64-char-random-string
# ALLOWED_ORIGINS: thay bằng domain thực tế của server
ALLOWED_ORIGINS=["http://YOUR_SERVER_IP:8019","https://yourdomain.com"]
